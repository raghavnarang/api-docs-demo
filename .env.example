# Provider secrets only. Adapter SELECTION lives in src/app/config.ts (typed),
# NOT here. These are read inside the respective adapter factories when added.

# --- Supabase (auth provider: "supabase") — DEFAULT ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Auth0 (auth provider: "auth0") ---
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=

# --- Firebase (auth provider: "firebase") ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# --- Custom JWT (auth provider: "custom-jwt") ---
VITE_JWT_API_BASE_URL=

# --- REST/GraphQL data sources (data source: "rest" | "graphql") ---
VITE_DATA_API_BASE_URL=
